%tr.client-status-row{ data: { client_status_id: client_status.id } }
  %td= client_status.id
  %td= client_status&.name
  %td= color_badge(client_status&.color, client_status&.color)
  %td
    = link_to client_status_path(client_status), method: :delete, class: 'text-danger', data: { confirm: tgm(:are_you_sure) }, remote: true, data: { tooltip: tc(:destroy) } do
      = g_icon(:delete, 'sm-g-icon')