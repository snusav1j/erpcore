= simple_form_for @client_status, remote: true, html: { id: 'client-status-form', novalidate: false } do |f|
  .form
    .row
      .col-md-12
        = f.input :name, required: true
      
    .row
      .col-md-12
        .form-group
          %label Цвет статуса
          .colorpicker-wrapper
            = f.input_field :color, class: 'colorpicker-input'