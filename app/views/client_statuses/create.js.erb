<% if @created %>
  $("#client-statuses-list").append("<%= j render partial: '/client_statuses/item', locals: { client_status: @client_status } %>");
  $('#client-status-modal').modal('hide');
  toastr.success('<%= tm(ClientStatus, :client_status_created) %>')
<% else %>
  toastr.danger('<%= tgm(:error) %>')
<% end %>

