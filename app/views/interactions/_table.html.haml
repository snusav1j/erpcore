.table-responsive
  %table.table-position-editor{ data: { entity: entity } }
    %thead
      %tr
        - columns.each do |column|
          %th{ data: { column_key: column[:key], position: column[:position] } }
            = column[:label]
        %th.static-position

    %tbody#interactions-list
      - if interactions
        - interactions.each do |interaction|
          = render partial: 'item', locals: { interaction: interaction, columns: columns }