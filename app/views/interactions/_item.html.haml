%tr.interaction-row{ data: { interaction_id: interaction.id } }
  %td= interaction.client&.name
  %td= interaction.interaction_type&.name
  %td= color_badge(interaction.interaction_status&.name, interaction.interaction_status&.color)
  %td= interaction.comment
  %td= interaction.manager&.email
  %td
    = link_to interaction_path(interaction), method: :delete, class: 'text-danger', data: { confirm: tgm(:are_you_sure) }, remote: true do
      = g_icon(:delete, 'sm-g-icon')