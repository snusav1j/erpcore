<% if @created %>
  $("#interactions-list").append("<%= j render partial: '/interactions/item', locals: { interaction: @interaction, columns: @columns } %>");
  $("tr.client-row[data-client-id='<%= @client.id %>']").replaceWith("<%= j render partial: '/clients/item', locals: { client: @client, columns: @client_columns } %>");
  $('#interaction-modal').modal('hide');
  toastr.success('<%= tm(Interaction, :interaction_created) %>')
<% else %>
  toastr.danger('<%= tgm(:error) %>')
<% end %>

