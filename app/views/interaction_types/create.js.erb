<% if @created %>
  $("#interaction-types-list").append("<%= j render partial: '/interaction_types/item', locals: { interaction_type: @interaction_type } %>");
  $('#interaction-type-modal').modal('hide');
  toastr.success('<%= tm(InteractionType, :interaction_type_created) %>')
<% else %>
  toastr.danger('<%= tgm(:error) %>')
<% end %>

