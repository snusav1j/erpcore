.modal.fade#client-type-modal
  .modal-dialog.modal-sm
    .modal-content
      .modal-header
        %h4.modal-title= title
        %button.close{ "aria-label" => "Close", "data-dismiss" => "modal", "type" => "button" }
          %span{"aria-hidden" => "true"}= g_icon(:close)
      .modal-body
        = render partial: '/client_types/form'
      .modal-footer
        %button.btn.btn-default.pull-left{"data-dismiss" => "modal", :type => "button"}= tgm(:cancel)
        %button.btn.btn-primary.pull-right{:type => "submit", form: 'client-type-form'}= tgm(:save)