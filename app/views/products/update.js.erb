<% if @updated %>
  $("tr.product-row[data-product-id='<%= @product.id %>']").replaceWith("<%= j render partial: '/products/item', locals: { product: @product } %>");
  $('#product-modal').modal('hide');
  toastr.success('<%= tm(Product, :product_updated) %>')
<% else %>
  toastr.danger('<%= tgm(:error) %>')
<% end %>