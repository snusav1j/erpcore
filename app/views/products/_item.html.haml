%tr.product-row{ data: { product_id: product.id } }
  - columns.each do |column|
    %td{ data: { column_key: column[:key], position: column[:position] } }
      - if column[:key] == :product_status_id
        = color_badge(product.product_status&.name, product.product_status&.color)
      - else
        = product.table_value(column[:key])

  %td.static-position
    = link_to product_path(product), method: :delete, class: 'text-danger', data: { confirm: tgm(:are_you_sure) }, remote: true do
      = g_icon(:delete, 'sm-g-icon')